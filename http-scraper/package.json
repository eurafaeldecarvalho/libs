{
    "name": "@rafaelgdn/http-scraper",
    "version": "0.1.0",
    "description": "Node.js port of hrequests with the official hrequests-cgo bridge and browser automation support",
    "author": "Rafael",
    "license": "MIT",
    "packageManager": "pnpm@10.28.1",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rafaelgdn/http-scraper.git"
    },
    "homepage": "https://github.com/rafaelgdn/http-scraper#readme",
    "bugs": {
        "url": "https://github.com/rafaelgdn/http-scraper/issues"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "keywords": [
        "hrequests",
        "requests",
        "scraping",
        "http",
        "tls",
        "http2",
        "browser",
        "playwright"
    ],
    "files": [
        "dist",
        "scripts/postinstall.mjs",
        "CHANGELOG.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "check": "tsc -p tsconfig.json --noEmit",
        "test": "node --import tsx --test tests/**/*.test.ts",
        "prepack": "pnpm build",
        "prepublishOnly": "pnpm release:check",
        "release:check": "mkdir -p ./.pack && pnpm check && pnpm test && pnpm pack --pack-destination ./.pack",
        "postinstall": "node ./scripts/postinstall.mjs"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "cheerio": "^1.1.2",
        "form-data-encoder": "^4.1.0",
        "formdata-node": "^6.0.3",
        "header-generator": "^2.1.82",
        "koffi": "^2.16.1",
        "mime-types": "^3.0.1",
        "playwright-core": "^1.55.0",
        "set-cookie-parser": "^2.7.1"
    },
    "devDependencies": {
        "@types/mime-types": "^3.0.1",
        "@types/node": "^24.6.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    }
}